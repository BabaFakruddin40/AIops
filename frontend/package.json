{
  "name": "aiops-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "AIops - AI-Powered Operations Automation Frontend",
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "axios": "^1.6.2",
    "socket.io-client": "^4.7.2",
    "recharts": "^2.10.3",
    "date-fns": "^2.30.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "vite": "^5.0.8",
    "eslint": "^8.50.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "prettier": "^3.0.3"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .jsx,.js --max-warnings 0",
    "lint:fix": "eslint src --ext .jsx,.js --fix",
    "format": "prettier --write 'src/**/*.{jsx,js,css}'",
    "format:check": "prettier --check 'src/**/*.{jsx,js,css}'"
  }
}
